{
  "name": "lockboxhq",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:webpack": "next dev --webpack",
    "clean:local": "rm -rf .next tsconfig.tsbuildinfo",
    "dev:clean": "npm run clean:local && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts middleware.ts next.config.mjs postcss.config.mjs eslint.config.mjs --cache --cache-location .eslintcache",
    "typecheck": "rm -rf .next/types .next/dev/types && ./scripts/sanitize_types.sh && tsc --noEmit",
    "preflight:env": "node scripts/preflight_env.mjs --mode=core",
    "preflight:env:core": "node scripts/preflight_env.mjs --mode=core",
    "preflight:env:meta": "node scripts/preflight_env.mjs --mode=meta",
    "preflight:env:solo-prod": "node scripts/preflight_env.mjs --mode=solo-prod",
    "smoke:solo": "node scripts/smoke_solo.mjs",
    "smoke:ingest": "./scripts/smoke_ingest.sh",
    "smoke:receptionist": "node scripts/smoke_receptionist.mjs",
    "security:rls:penetration": "node scripts/rls_penetration.mjs",
    "release:check": "npm run preflight:env:solo-prod && npm run typecheck && npm run lint && npm run build",
    "release:check:local": "npm run preflight:env:core && npm run typecheck && npm run lint && npm run build",
    "release:check:with-smoke": "npm run release:check:local && npm run smoke:solo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.183.1",
    "date-fns": "^4.1.0",
    "imapflow": "^1.2.16",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^16.1.6",
    "nodemailer": "^8.0.3",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
